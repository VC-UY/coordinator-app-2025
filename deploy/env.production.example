# Coordinator repository production example.
# Copy this file to deploy/.env.production and fill secrets.

DJANGO_SECRET_KEY=CHANGE_ME_STRONG_SECRET
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,coordinator-vc-uy.npe-techs.com

# Public URLs
COORDINATOR_PUBLIC_URL=http://localhost:8001
MANAGER_PUBLIC_URL=http://localhost:8002
COORDINATOR_PUBLIC_IP=127.0.0.1

# Mongo / Redis
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_NAME=coordinator_db
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PROXY_PORT=6380
USE_REDIS_PROXY=True
